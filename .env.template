# ========================================
# PLANTILLA DE CONFIGURACIÓN SHAREPOINT
# ========================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como ".env" en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. NUNCA subas este archivo a Git (ya está en .gitignore)
# 4. Consulta CONFIGURACION-SHAREPOINT.md para obtener estos valores
#
# ========================================

# ========================================
# HABILITAR SHAREPOINT
# ========================================
# Cambiar a "true" para activar la integración con SharePoint
# Si está en "false", los archivos se guardan localmente
SHAREPOINT_ENABLED=false

# ========================================
# CREDENCIALES DE AZURE AD
# ========================================
# Obtener desde: Azure Portal > Azure Active Directory > App registrations

# Tenant ID (Directory ID)
# Ejemplo: 12345678-1234-1234-1234-123456789abc
SHAREPOINT_TENANT_ID=

# Client ID (Application ID)
# Ejemplo: 87654321-4321-4321-4321-cba987654321
SHAREPOINT_CLIENT_ID=

# Client Secret (Application Secret)
# IMPORTANTE: Se muestra solo una vez al crearlo
# Ejemplo: abc123~DEF456.ghi789-JKL012_mno345
SHAREPOINT_CLIENT_SECRET=

# ========================================
# IDS DE SHAREPOINT
# ========================================
# Obtener usando Microsoft Graph Explorer o PowerShell

# Site ID
# Obtener con: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/{site-name}
# Ejemplo: miempresa.sharepoint.com,abc123-def456-ghi789,xyz987-uvw654-rst321
SHAREPOINT_SITE_ID=

# Drive ID (Biblioteca de documentos)
# Obtener con: GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
# Ejemplo: b!abc123def456ghi789jkl012mno345pqr678stu901vwx234yz
SHAREPOINT_DRIVE_ID=

# ========================================
# CONFIGURACIÓN DE CARPETA
# ========================================
# Nombre de la carpeta donde se subirán los archivos
# NOTA: Esta carpeta debe existir en SharePoint
# Si no existe, créala manualmente antes de usar la aplicación
SHAREPOINT_FOLDER_PATH=Reportes

# ========================================
# NOTAS IMPORTANTES
# ========================================
#
# SEGURIDAD:
# - Mantén este archivo seguro y privado
# - No lo compartas por email o chat
# - Usa un gestor de contraseñas para guardar una copia
# - Rota el Client Secret regularmente
#
# PERMISOS NECESARIOS EN AZURE AD:
# - Sites.ReadWrite.All (Application permission)
# - Files.ReadWrite.All (Application permission)
# - Debe tener "Admin consent granted" ✅
#
# VERIFICACIÓN:
# - Después de configurar, ejecuta: mvn spring-boot:run
# - Abre http://localhost:8080
# - Haz clic en "⚙️ Estado SharePoint"
# - Verifica que todo muestre ✓
#
# AYUDA:
# - Guía completa: CONFIGURACION-SHAREPOINT.md
# - Documentación: README.md
# - Graph Explorer: https://developer.microsoft.com/graph/graph-explorer
#
# ========================================
