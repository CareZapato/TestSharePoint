# ========================================
# EJEMPLO DE CONFIGURACIÓN SHAREPOINT
# ========================================
# 
# Para usar este archivo:
# 1. Copia como ".env" en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo
# 3. Consulta CONFIGURACION-SHAREPOINT.md para guía detallada
#
# ========================================

# Habilitar integración con SharePoint (true/false)
SHAREPOINT_ENABLED=false

# Credenciales de Azure AD / Microsoft 365
# Obtener desde: https://portal.azure.com > Azure Active Directory > App registrations
SHAREPOINT_TENANT_ID=tu-tenant-id-aqui
SHAREPOINT_CLIENT_ID=tu-client-id-aqui
SHAREPOINT_CLIENT_SECRET=tu-client-secret-aqui

# IDs de SharePoint
# Site ID: Obtener desde Graph Explorer o PowerShell
# Drive ID: ID de la biblioteca de documentos
SHAREPOINT_SITE_ID=tu-site-id-aqui
SHAREPOINT_DRIVE_ID=tu-drive-id-aqui

# Carpeta destino en SharePoint (relativa a la raíz del drive)
SHAREPOINT_FOLDER_PATH=Reportes

# ========================================
# CÓMO OBTENER LOS VALORES
# ========================================
#
# TENANT ID:
#   Azure Portal > Azure Active Directory > Properties > Tenant ID
#
# CLIENT ID y SECRET:
#   1. Azure Portal > App registrations > New registration
#   2. Nombre: SharePoint Payment Lab
#   3. Después de crear, anota el Application (client) ID
#   4. Ve a Certificates & secrets > New client secret
#   5. Copia el VALUE (no el Secret ID) inmediatamente
#
# PERMISOS REQUERIDOS:
#   API permissions > Add permission > Microsoft Graph > Application permissions
#   - Sites.ReadWrite.All
#   - Files.ReadWrite.All
#   ⚠️ Importante: Grant admin consent
#
# SITE ID:
#   Opción 1 - Graph Explorer:
#     GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/{site-name}
#     Ejemplo: sites/miempresa.sharepoint.com:/sites/pagos
#
#   Opción 2 - PowerShell:
#     Connect-MgGraph -Scopes "Sites.Read.All"
#     Get-MgSite -Search "Nombre del sitio"
#
# DRIVE ID:
#   Graph Explorer:
#     GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
#   Busca el drive con name="Documents" o el nombre de tu biblioteca
#
# ========================================
# MÁS INFORMACIÓN
# ========================================
