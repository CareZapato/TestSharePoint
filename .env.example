# Ejemplo de variables de entorno para integración con SharePoint
# Copiar este archivo como .env y completar con tus credenciales

# Habilitar integración con SharePoint (true/false)
SHAREPOINT_ENABLED=false

# Credenciales de Azure AD / Microsoft 365
# Obtener desde: https://portal.azure.com > Azure Active Directory > App registrations
SHAREPOINT_TENANT_ID=tu-tenant-id-aqui
SHAREPOINT_CLIENT_ID=tu-client-id-aqui
SHAREPOINT_CLIENT_SECRET=tu-client-secret-aqui

# IDs de SharePoint
# Site ID: Obtener desde Graph Explorer o PowerShell
# Drive ID: ID de la biblioteca de documentos
SHAREPOINT_SITE_ID=tu-site-id-aqui
SHAREPOINT_DRIVE_ID=tu-drive-id-aqui

# Carpeta destino en SharePoint (relativa a la raíz del drive)
SHAREPOINT_FOLDER_PATH=Reportes

# Ejemplo de cómo obtener estos valores:
# 1. Tenant ID: Portal Azure > Azure Active Directory > Properties > Tenant ID
# 2. Client ID y Secret: Portal Azure > App registrations > New registration
# 3. Site ID: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/{site-name}
# 4. Drive ID: GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
